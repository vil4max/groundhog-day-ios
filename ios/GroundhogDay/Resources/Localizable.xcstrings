    "push.alarm.5" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It's Groundhog Day! At the crack of dawn, everyone's going to be lining up at Gobbler's Knob."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сегодня День сурка! На рассвете все выстроятся в очередь на Курином холме."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
