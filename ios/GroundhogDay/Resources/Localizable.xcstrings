    "push.alarm.1" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Okay, campers, rise and shine, and don't forget your booties 'cause it's cooooold out there today."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ну что, ребята, подъём! И не забудьте тапочки — на улице сегодня оооочень холодно."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ну що, друзі, підйом! І не забудьте тапочки — на вулиці сьогодні дуууже холодно."
          }
        }
      }
    },
