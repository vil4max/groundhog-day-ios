    "countdown.quote.1" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Well, what if there is no tomorrow? There wasn't one today."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "А что, если завтра не наступит? Сегодня ведь его не было."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "А що, якщо завтра не настане? Сьогодні ж його не було."
          }
        }
      }
    },
    "countdown.quote.2" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This is one time where television really fails to capture the true excitement of a large squirrel predicting the weather."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Это тот случай, когда телевидение не способно передать весь восторг от сурка, предсказывающего погоду."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Це той випадок, коли телебачення не здатне передати весь захват від бабака, що передбачає погоду."
          }
        }
      }
    },
    "countdown.quote.3" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I'm a god. I'm not the God… I don't think."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я бог. Не Бог… наверное."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Я бог. Не Бог… напевно."
          }
        }
      }
    },
    "countdown.quote.4" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Don't drive angry!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не злись за рулём!"
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Не злися за кермом!"
          }
        }
      }
    },
    "countdown.quote.6" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "It's gonna be cold, it's gonna be gray, and it's gonna last you for the rest of your life."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Будет холодно, будет серо, и это продлится всю твою жизнь."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Буде холодно, буде сіро, і це триватиме все твоє життя."
          }
        }
      }
    },
    "countdown.quote.7" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I have been stabbed, shot, poisoned, frozen, hung, electrocuted, and burned."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Меня резали, стреляли в меня, травили, замораживали, вешали, били током и сжигали."
          }
        },
        "uk" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Мене різали, стріляли в мене, отруювали, заморожували, вішали, били струмом і спалювали."
          }
        }
      }
    },
    "countdown.quote.8" : {
      "extractionState" : "stale",
      "localizations" : {
